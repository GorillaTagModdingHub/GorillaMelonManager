<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="GorillaMelonManager.Views.ModBrowser"
			 Width="500"
			 Height="400"
			 x:DataType="viewModels:ModBrowserViewModel"
			 xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
			 xmlns:viewModels="clr-namespace:GorillaMelonManager.ViewModels">
	<Panel>
		<TextBlock HorizontalAlignment="Center"
			VerticalAlignment="Center"
			Foreground="Black"
			FontSize="24"
			IsVisible="{Binding !ModsFetched}">Fetching mods, please be patient!</TextBlock>

		<Grid Margin="10 2">
			<ScrollViewer>
				<ItemsRepeater ItemsSource="{Binding ModsForPage}">
					<ItemsRepeater.Layout>
						<UniformGridLayout Orientation="Horizontal"/>
					</ItemsRepeater.Layout>

					<ItemsRepeater.ItemTemplate>
						<DataTemplate>
							<Border Background="#1F1F1F"
								BorderBrush="#1F1F1F"
								BorderThickness="5"
								CornerRadius="5"
								Width="235"
								Height="150"
								Margin="2"
								ClipToBounds="True">
								<Panel>
									<Image
										Height="135"
										Width="220"
										Stretch="UniformToFill"
										asyncImageLoader:ImageLoader.Source="{Binding ThumbnailImageUrl}"/>

									<Panel
										Width="235"
										Height="25"
										Background="#1f1f1f"
										Opacity="100"
										VerticalAlignment="Top"/>

									<Panel
										Width="235"
										Height="40"
										Background="#1f1f1f"
										Opacity="100"
										VerticalAlignment="Bottom"/>

									<TextBlock Margin="5" TextAlignment="Center">
										<Run Text="{Binding ModName}"/>
										<Run Foreground="Gray" Text="by"/>
										<Run Foreground="Gray" Text="{Binding ModAuthor}"/>
									</TextBlock>

									<TextBlock
										HorizontalAlignment="Left"
										VerticalAlignment="Bottom"
										Margin="5"
										FontSize="12">
										<Run Text="Likes:"/>
										<Run Text="{Binding LikesCount}"/>
										<Run Text="&#x0a;Downloads:"/>
										<Run Text="{Binding DownloadsCount}"/>
									</TextBlock>

									<Button Content="Install"
											Command="{Binding InstallMod}"
											Margin="5"
											VerticalAlignment="Bottom"
											HorizontalAlignment="Right"
											Background="Green"/>
								</Panel>
							</Border>
						</DataTemplate>
					</ItemsRepeater.ItemTemplate>
				</ItemsRepeater>
			</ScrollViewer>
		</Grid>
	</Panel>
</UserControl>
